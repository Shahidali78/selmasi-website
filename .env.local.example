# ============================================================
# SELMASI ENVIRONMENT VARIABLES
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local to version control.
# ============================================================

# PayGate Integration (server-side only — never expose secrets in frontend code)
NEXT_PUBLIC_PAYGATE_MERCHANT_ID=
PAYGATE_SECRET_KEY=
PAYGATE_PASSPHRASE=

# Mode: "test" or "live"
NEXT_PUBLIC_PAYGATE_MODE=test

# PayGate initiate payment URL
NEXT_PUBLIC_PAYGATE_URL=https://secure.paygate.co.za/payweb3/initiate.trans

# Return URL after payment (your domain)
NEXT_PUBLIC_PAYGATE_RETURN_URL=https://selmasi.africa/payment/return

# Notify URL (server-side webhook — must be HTTPS)
PAYGATE_NOTIFY_URL=https://selmasi.africa/api/payment/notify
